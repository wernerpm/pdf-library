# Copy to .env and fill in values.
# Never commit .env to source control — it is listed in .gitignore.

# Secret key for signing JWTs (REQUIRED).
# Generate one with: openssl rand -hex 32
JWT_SECRET=

# Public HTTPS URL of the app (REQUIRED for cloud deployment).
# Must match the rpId in config.json.
# Example: https://library.example.com
APP_URL=
